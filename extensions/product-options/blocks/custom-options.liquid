{% comment %}
  Custom Product Options - renders dynamic fields based on templates
{% endcomment %}

{{ 'product-fields.css' | asset_url | stylesheet_tag }}

<style>
  .variantiq-product-options {
    --button-bg: {{ section.settings.button_background | default: '#ffffff' }};
    --button-border: {{ section.settings.button_border | default: '#dddddd' }};
    --button-text: {{ section.settings.button_text | default: '#333333' }};
    --button-selected-bg: {{ section.settings.button_selected_background | default: '#121212' }};
    --button-selected-text: {{ section.settings.button_selected_text | default: '#ffffff' }};
    --button-radius: {{ section.settings.button_border_radius | default: 4 }}px;
    --button-padding: {{ section.settings.button_padding | default: 10 }}px;
  }
</style>


{% if request.design_mode %}
  <div class="variantiq-editor-placeholder">
    <div class="variantiq-editor-placeholder__header">
      <strong class="variantiq-editor-placeholder__title">VariantIQ — Custom Product Options</strong>
      <svg class="variantiq-editor-placeholder__icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <p class="variantiq-editor-placeholder__desc">
      Custom product options will appear here. <strong>(only shown in editor)</strong>
    </p>
    <p class="variantiq-editor-placeholder__hint">
      To configure options, visit the <strong>VariantIQ</strong> app in your Shopify admin.
    </p>
  </div>

  <style>
    .variantiq-editor-placeholder {
      border: 3px solid #3eb8d4;
      border-radius: 8px;
      background: linear-gradient(135deg, #43c6e4 0%, #3498db 100%);
      color: #fff;
      padding: 18px 20px;
      margin: 12px 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      position: relative;
    }
    .variantiq-editor-placeholder__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    .variantiq-editor-placeholder__title {
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.2px;
    }
    .variantiq-editor-placeholder__icon {
      flex-shrink: 0;
      opacity: 0.9;
    }
    .variantiq-editor-placeholder__desc {
      font-size: 13.5px;
      margin: 0 0 6px 0;
      line-height: 1.5;
    }
    .variantiq-editor-placeholder__hint {
      font-size: 12.5px;
      margin: 0;
      opacity: 0.9;
      line-height: 1.4;
    }
  </style>
{% else %}
  <div 
    class="variantiq-product-options" 
    data-product-id="{{ product.id }}"
    data-shop="{{ shop.permanent_domain }}"
    data-api-url="https://variantiq-dev.saasyllama.com"
  >
    {% if section.settings.show_heading %}
      <h3 class="variantiq-heading">{{ section.settings.heading }}</h3>
    {% endif %}

    <div id="variantiq-fields-{{ product.id }}" class="variantiq-fields-container">
      <div class="variantiq-loading">
        <p>Loading options...</p>
      </div>
    </div>

    <div id="variantiq-error" class="variantiq-error" style="display: none;">
      <p>Unable to load product options. Please refresh the page.</p>
    </div>
  </div>

  <script src="{{ 'product-fields.js' | asset_url }}?v=2" defer></script>
{% endif %}

{% schema %}
{
  "name": "Custom Product Options",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customize Your Product"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "header",
      "content": "Button Styling"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border",
      "label": "Button border color",
      "default": "#dddddd"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_selected_background",
      "label": "Selected button padding/background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_selected_text",
      "label": "Selected button text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Button padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    }
  ]
}
{% endschema %}
