generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String   @id
  shop          String
  state         String
  isOnline      Boolean  @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String   @default("")
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean? @default(false)
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop])
}


model Template {
  id        String   @id @default(cuid())
  shop      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fontFamily           String?
  fontSize             String?
  fontWeight           String?
  textColor            String?
  backgroundColor      String?
  borderColor          String?
  borderRadius         String?
  padding              String?
  hoverBackgroundColor String?
  hoverTextColor       String?

  fields    Field[]
  rules     Rule[]
  links     ProductTemplateLink[]

  @@index([shop])
}

model Field {
  id          String   @id @default(cuid())
  templateId  String
  type        String   // text | select | radio | checkbox
  name        String
  label       String
  optionsJson Json?
  required    Boolean  @default(false)
  sort        Int      @default(0)
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Rule {
  id               String   @id @default(cuid())
  templateId       String
  
  // E.g., [{ "fieldId": "A", "operator": "EQUALS", "value": "Adult" }]
  conditionsJson   Json     
  
  // Field to act upon (e.g., 'Color')
  targetFieldId    String   
  
  // "SHOW", "HIDE", "LIMIT_OPTIONS"
  actionType       String   @default("SHOW") 
  
  // Allowed choices if LIMIT_OPTIONS (e.g., ["Red", "Blue"])
  targetOptionsJson Json?   
  
  sort             Int      @default(0)
  template         Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  @@index([templateId])
  @@index([targetFieldId])
}

model ProductTemplateLink {
  id          String   @id @default(cuid())
  shop        String
  productGid  String   // gid://shopify/Product/...
  templateId  String
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([shop])
  @@index([productGid])
  @@index([templateId])
}
